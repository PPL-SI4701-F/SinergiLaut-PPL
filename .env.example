# ===========================================
# PPL SINERGILAUT - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control!

# ---------------------------
# Supabase (Required)
# ---------------------------
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connections for Prisma
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/database
# Transaction pooler (port 6543) — used by app (pgbouncer)
DATABASE_URL="postgres://postgres.[your-project-id]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler / direct (port 5432) — used by Prisma migrations
DIRECT_URL="postgres://postgres.[your-project-id]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ---------------------------
# App Config
# ---------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SinergiLaut

# ---------------------------
# Supabase Storage
# ---------------------------
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sinergilaut-assets

# ---------------------------
# Midtrans Payment Gateway (Required for Donations)
# ---------------------------
# Register at: https://dashboard.sandbox.midtrans.com (sandbox/testing)
# Server Key: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
# Client Key (used in frontend for Snap.js):
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Mode: "false" = sandbox (testing), "true" = production
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ---------------------------
# Map (Optional)
# ---------------------------
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# ---------------------------
# Analytics (Optional)
# ---------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
